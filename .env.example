# Primary LLM provider. If set, Anthropic is used before CGC.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6

# Comtegra CGC (OpenAI-compatible). Use as main provider or fallback path.
CGC_LLM_BASE_URL=https://llm.comtegra.cloud/v1
CGC_LLM_API_KEY=
CGC_LLM_CHAT_MODEL=devstral-small-2-24b

# Persistent orchestration state.
DATABASE_URL=
MONGODB_DATABASE=civil42-DB

# Frontend / Civil42 API used for incidents, organizations, and resources.
NEXTJS_API_BASE_URL=http://localhost:3000
NEXTJS_API_TOKEN=

# Phone tool integration.
PHONE_AGENT_ENABLED=true
PHONE_AGENT_BASE_URL=http://localhost:5000
PHONE_AGENT_API_TOKEN=
PHONE_AGENT_DEFAULT_PHONE_NUMBER=

# Workflow and logging.
ORCHESTRATOR_VERSION=v1
ORCHESTRATION_LOG_FILE=logs/orchestration-trace.log
ORCHESTRATION_HUMAN_LOG_FILE=logs/orchestration-pretty.log

# Default org used by intake/report flows when org is not provided explicitly.
INTAKE_DEFAULT_ORG_EXTERNAL_ID=org_kghm

# Browser clients allowed to call the API.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
