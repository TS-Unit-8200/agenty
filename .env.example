# Comtegra GPU Cloud — LLM inference API (OpenAI-compatible).
# Docs: https://docs.cgc.comtegra.cloud/llm-api
# Create keys: cgc api-keys create --level LLM
CGC_LLM_BASE_URL=https://llm.comtegra.cloud/v1
CGC_LLM_API_KEY=
# Example model from docs; pick one available in your CGC account.
CGC_LLM_CHAT_MODEL=llama3-8b

# MongoDB Atlas (optional — paste your mongodb+srv URI from Atlas).
# If the URI has no database path (…mongodb.net/?appName=…), set MONGODB_DATABASE.
DATABASE_URL=
MONGODB_DATABASE=

# Next.js service URL for resource CRUD proxy MCP.
NEXTJS_API_BASE_URL=http://localhost:3000
NEXTJS_API_TOKEN=

# Orchestrator idempotency/version marker.
ORCHESTRATOR_VERSION=v1

# Optional orchestration trace log file.
ORCHESTRATION_LOG_FILE=logs/orchestration-trace.log
